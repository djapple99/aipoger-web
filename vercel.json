{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.aipoger.com"
        }
      ],
      "destination": "https://aipoger.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/listen-bar/process-rotation",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/battle-pool/process-fallbacks",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "src/app/api/upload-hook/route.ts": {
      "maxDuration": 120
    }
  }
}
